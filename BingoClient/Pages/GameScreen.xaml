<Page x:Class="BingoClient.Pages.GameScreen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BingoClient.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GameScreen"
      Background="#363636">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="33*" />
            <RowDefinition Height="33*" />
            <RowDefinition Height="33*" />
        </Grid.RowDefinitions>


        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="0">
            <TextBlock Name="CurrentNumber"
                    TextWrapping="NoWrap" VerticalAlignment="Center" TextAlignment="Center"
                    Text="0" FontSize="60" FontWeight="Bold" Background="White" Padding="10,1,10,1"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1">
            <Button x:Name="fiveNumbersButton"
                    Width="130"
                    Margin="0 0 10 0"
                    Padding="12 20"
                    Background="LightCyan"
                    Foreground="DarkCyan"
                    BorderBrush="DarkCyan"
                    BorderThickness="1"
                    Click="fiveNumbersButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="40"/>
                    </Style>
                </Button.Resources>
                5 Primers Números
            </Button>
            <Button x:Name="bingoButton"
                    Width="130"
                    Margin="0 0 10 0"
                    Padding="12 20"
                    Background="LightCyan"
                    Foreground="DarkCyan"
                    BorderBrush="DarkCyan"
                    BorderThickness="1"
                    Click="bingoButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="40"/>
                    </Style>
                </Button.Resources>
                Bingo
            </Button>
        </StackPanel>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2">

            <Button
                Width="50" Height="50"
                Background="White" Foreground="Gray" BorderBrush="Gray"
                BorderThickness="1"
                Click="numberClick">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
                N
            </Button>

        </StackPanel>
    </Grid>
</Page>
