<Page x:Class="BingoClient.Pages.GameScreen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#363636">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Top: Room info + start -->
            <RowDefinition Height="Auto"/>
            <!-- Current Number -->
            <RowDefinition Height="*"/>
            <!-- Bingo card buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom: 5 numbers / Bingo -->
        </Grid.RowDefinitions>

        <!-- Top panel -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">
            <TextBlock Text="Room:"
                       Foreground="White"
                       Margin="0,0,5,0"/>
            <TextBlock x:Name="RoomText"
                       Foreground="LightBlue"
                       FontWeight="Bold"/>
            <Button x:Name="StartButton"
                    Content="Start Game"
                    Margin="20,0,0,0"
                    Click="StartGame_Click"/>
        </StackPanel>

        <!-- Current number display -->
        <TextBlock x:Name="CurrentNumber"
                   Grid.Row="1"
                   Text="0"
                   FontSize="60"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,10,0,10"/>

        <!-- Bingo card buttons (5x3) -->
        <UniformGrid Grid.Row="2"
                     x:Name="BingoCardGrid"
                     Rows="3"
                     Columns="5"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Margin="0,10,0,10">
            <!-- Buttons will be added dynamically in code-behind -->
        </UniformGrid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">
            <Button Content="5 Numbers"
                    Width="120"
                    Margin="5"
                    Click="fiveNumbersButton_Click"/>
            <Button Content="Bingo"
                    Width="120"
                    Margin="5"
                    Click="bingoButton_Click"/>
        </StackPanel>
    </Grid>
</Page>